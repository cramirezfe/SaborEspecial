# Sabor Especial — Environment Variables
# Run `npm run setup` and this file is generated for you automatically.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # backend only — never expose in the browser

# ── Database (for npm run init-db) ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DB_PASSWORD=your-db-password       # stored so re-running setup doesn't re-ask

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000

# ── Access passwords (share only with staff) ──────────────────────────────────
ADMIN_SECRET=generated-by-setup
ORDERS_PASSWORD=generated-by-setup

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*                      # set to exact origin in production

# ── Email (optional) ─────────────────────────────────────────────────────────
RESEND_API_KEY=                    # blank = email silently skipped

# ── Local dev ─────────────────────────────────────────────────────────────────
CAFETERIA_SLUG=test-cafeteria
