# Sabor Especial — Environment Variables
# Copy this file to .env.local and fill in your values.
# Or just run:  bash setup.sh   (it generates .env.local automatically)

# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings → API in your Supabase dashboard
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Keep this secret — backend only

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000  # Change to your Vercel URL in production

# ── Auth passwords (share only with staff) ────────────────────────────────────
ADMIN_SECRET=change-me             # Admin panel login
ORDERS_PASSWORD=change-me          # Kitchen delivery screen login

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*                      # Set to exact frontend origin in production

# ── Email (optional) ─────────────────────────────────────────────────────────
# Leave blank to skip order confirmation emails locally.
# Get a free API key at https://resend.com
RESEND_API_KEY=

# ── Local dev ─────────────────────────────────────────────────────────────────
# Slug of the test cafeteria created by scripts/seed.js
CAFETERIA_SLUG=test-cafeteria
